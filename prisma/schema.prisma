// Sauraha Fish Village & Agro Pvt. Ltd - Resort Management System
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CUSTOMER
  RECEPTION
  MANAGER
  ADMIN
}

enum RoomStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
  MAINTENANCE
  CLEANING
  RESERVED
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  REFUNDED
}

enum PaymentMethod {
  QR_PAYMENT
  FONEPAY
  ESEWA
  KHALTI
  CASH
}


enum StaffStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum InventoryCategory {
  FOOD_INGREDIENTS
  CLEANING_SUPPLIES
  KITCHEN_INVENTORY
  ROOM_SUPPLIES
}

enum NotificationType {
  BOOKING_CONFIRMATION
  PAYMENT_VERIFICATION
  CHECKIN_REMINDER
  CHECKOUT_REMINDER
  GENERAL
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  SERVED
  COMPLETED
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  phone         String?
  address       String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings      Booking[]
  payments      Payment[]      @relation("PaymentUser")
  verifiedPayments Payment[]   @relation("PaymentVerifier")
  notifications Notification[]
  staff         Staff?
  auditLogs     AuditLog[]
  accounts      Account[]
  sessions      Session[]
  settings      Setting[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id          String     @id @default(cuid())
  number      Int        @unique
  name        String
  type        RoomType   @default(STANDARD)
  capacity    Int        @default(2)
  pricePerNight Float
  dayPrice    Float?
  nightPrice  Float?
  wholeDayPrice Float?
  status      RoomStatus @default(AVAILABLE)
  description String?    @db.Text
  amenities   Json
  images      Json
  floor       Int        @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings Booking[]

  @@index([status])
  @@index([type])
}

model Booking {
  id             String        @id @default(cuid())
  bookingNumber  String        @unique @default(cuid())
  userId         String
  roomId         String
  checkIn        DateTime
  checkOut       DateTime
  actualCheckIn  DateTime?
  actualCheckOut DateTime?
  expectedCheckInTime  String?
  expectedCheckOutTime String?
  guests         Int           @default(1)
  specialRequests String?      @db.Text
  totalAmount    Float
  bookingType    String?
  status         BookingStatus @default(PENDING)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  room     Room      @relation(fields: [roomId], references: [id])
  payment  Payment?
  receipt  Receipt?

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([checkIn, checkOut])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  userId        String
  amount        Float
  method        PaymentMethod @default(QR_PAYMENT)
  transactionId String?
  screenshotUrl String?
  status        PaymentStatus @default(PENDING)
  verifiedById  String?
  verifiedAt    DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking    Booking  @relation(fields: [bookingId], references: [id])
  user       User     @relation("PaymentUser", fields: [userId], references: [id])
  verifiedBy User?    @relation("PaymentVerifier", fields: [verifiedById], references: [id])
  receipt    Receipt?

  @@index([status])
  @@index([userId])
}

model Receipt {
  id            String @id @default(cuid())
  receiptNumber String @unique
  bookingId     String @unique
  paymentId     String @unique
  qrCode        String? @db.Text
  pdfUrl        String?

  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])
}

model MenuCategory {
  id        String @id @default(cuid())
  name      String @unique
  slug      String @unique
  sortOrder Int    @default(0)
  image     String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items MenuItem[]

  @@index([slug])
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  price       Float
  image       String?
  available   Boolean @default(true)
  categoryId  String
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category MenuCategory @relation(fields: [categoryId], references: [id])
  restaurantOrderItems RestaurantOrderItem[]

  @@index([categoryId])
  @@index([available])
}

model Staff {
  id        String        @id @default(cuid())
  userId    String        @unique
  position  String
  salary    Float?
  shift     ShiftType     @default(MORNING)
  status    StaffStatus   @default(ACTIVE)
  joinDate  DateTime      @default(now())
  phone     String?
  emergencyContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user       User         @relation(fields: [userId], references: [id])
  attendance Attendance[]

  @@index([position])
  @@index([status])
}

model Attendance {
  id       String   @id @default(cuid())
  staffId  String
  date     DateTime
  checkIn  DateTime?
  checkOut DateTime?
  status   String   @default("PRESENT")
  notes    String?

  createdAt DateTime @default(now())

  // Relations
  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
}

model Inventory {
  id            String            @id @default(cuid())
  name          String
  category      InventoryCategory
  quantity      Float             @default(0)
  unit          String            @default("pcs")
  minStock      Float             @default(10)
  costPerUnit   Float?
  supplier      String?
  supplierPhone String?
  lastRestocked DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType @default(GENERAL)
  title   String
  message String           @db.Text
  read    Boolean          @default(false)
  link    String?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
}

model AuditLog {
  id       String @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String?
  details  String? @db.Text
  ipAddress String?

  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy User? @relation(fields: [updatedById], references: [id])
}

model RestaurantTable {
  id       String      @id @default(cuid())
  name     String      @unique // e.g., "Table 1", "Poolside 1"
  capacity Int         @default(4)
  status   TableStatus @default(AVAILABLE)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders RestaurantOrder[]
}

model RestaurantOrder {
  id          String      @id @default(cuid())
  tableId     String
  customerName String?
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)
  notes       String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  table RestaurantTable       @relation(fields: [tableId], references: [id])
  items RestaurantOrderItem[]

  @@index([tableId])
  @@index([status])
}

model RestaurantOrderItem {
  id           String @id @default(cuid())
  orderId      String
  menuItemId   String
  quantity     Int    @default(1)
  priceAtOrder Float  // To support dynamic overriding
  notes        String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  order    RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem        @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}
